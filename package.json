{
  "name": "mes",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "docker:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/compose/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/compose/docker-compose.yml logs -f",
    "setup": "pnpm install && pnpm docker:up && pnpm turbo dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
