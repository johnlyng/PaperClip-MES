{
  "name": "@mes/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.mjs",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "generate-telemetry": "tsx src/scripts/generate-telemetry.ts"
  },
  "dependencies": {
    "@mes/db": "workspace:*",
    "@mes/domain": "workspace:*",
    "@mes/test-fixtures": "workspace:*",
    "@mes/types": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/websocket": "^11.0.2",
    "@fastify/jwt": "^9.0.3",
    "@fastify/cors": "^10.0.2",
    "drizzle-orm": "^0.40.0",
    "postgres": "^3.4.5",
    "mqtt": "^5.10.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "*",
    "tsx": "^4.19.2",
    "typescript": "*",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "aedes": "^0.51.3",
    "testcontainers": "^10.13.2"
  }
}
