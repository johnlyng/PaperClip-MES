# MES API — environment variables
# Copy to .env.local and fill in values for local development.

# PostgreSQL + TimescaleDB
DATABASE_URL=postgresql://mes:mes@localhost:5432/mes_dev

# EMQX MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Authentication
JWT_SECRET=dev-only-secret-change-me-in-production

# Server
API_PORT=3000
API_HOST=0.0.0.0

# CORS — origin allowed for browser requests
CORS_ORIGIN=http://localhost:5173

# Observability
LOG_LEVEL=info
