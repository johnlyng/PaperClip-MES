# MES OPC-UA Collector — environment variables
# Copy to .env.local and fill in values for local development.
# When OPCUA_ENDPOINTS is empty the collector runs in synthetic telemetry mode.

# EMQX MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# OPC-UA endpoints (JSON array of endpoint URLs)
# Example: ["opc.tcp://plc1:4840", "opc.tcp://plc2:4840"]
OPCUA_ENDPOINTS=[]

# OPC-UA security policy: None | Basic256Sha256 | Aes128_Sha256_RsaOaep
OPCUA_SECURITY_POLICY=None

# Observability
LOG_LEVEL=info
