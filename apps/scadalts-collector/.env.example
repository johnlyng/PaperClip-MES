# MES Scada-LTS Collector — environment variables
# Copy to .env.local and fill in values for local development.

# Scada-LTS REST API base URL
SCADALTS_BASE_URL=http://localhost:8080

# Scada-LTS credentials
SCADALTS_USERNAME=admin
SCADALTS_PASSWORD=

# EMQX MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Observability
LOG_LEVEL=info
