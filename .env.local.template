# MES Local Development Environment
# Copy this file to .env.local and adjust as needed.
# Do NOT commit .env.local to version control.

# PostgreSQL + TimescaleDB
DATABASE_URL=postgresql://mes:mes@localhost:5432/mes_dev

# EMQX MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Scada-LTS Collector (ADR-001 Decision 7, amended — replaces OPC-UA collector)
SCADALTS_BASE_URL=http://localhost:8080
SCADALTS_PASSWORD=dev-password

# Authentication
# RS256 private key path or shared secret (dev only)
JWT_SECRET=dev-only-secret-change-me-in-production

# API Service
API_PORT=3000
API_HOST=0.0.0.0

# Web (Vite dev server)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# ERP Integration (adapter is MockERPAdapter until board decides target ERP)
ERP_ADAPTER=mock
# SAP-specific (when ERP_ADAPTER=sap)
# SAP_BASE_URL=
# SAP_CLIENT=
# SAP_USERNAME=
# SAP_PASSWORD=

# Observability
LOG_LEVEL=info
